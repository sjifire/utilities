# Git
.git
.gitignore

# Python
__pycache__
*.pyc
.venv
.pytest_cache
.ruff_cache
.mypy_cache

# Dev/CI files
tests/
scripts/
.github/
.claude/
.env

# Root-level markdown (keep README, exclude others like CLAUDE.md)
*.md
!README.md

# Include all docs/ content (overrides *.md and *.html above)
!docs/
!docs/**

# Images and misc
*.jpg
*.png
**/.DS_Store
